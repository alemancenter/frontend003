# Copy to /var/www/vhosts/alemancenter.com/api-server/.env  (chmod 600)
# ─────────────────────────────────────────────────────────────────────────────

# Local port the Node service listens on (loopback only; nginx proxies to it).
PORT=8080

NODE_ENV=production
LOG_LEVEL=info

# The SECRET shared with the Go backend. Use the SAME value the upstream
# api.alemancenter.com FrontendGuard expects (the one the current setup uses).
ALEMANCENTER_FRONTEND_API_KEY=REPLACE_WITH_REAL_FRONTEND_KEY

# Browser origins allowed to call the API with credentials. In production the
# allowlist FAILS CLOSED, so this MUST list the live origins.
ALLOWED_ORIGINS=https://alemancenter.com,https://www.alemancenter.com
